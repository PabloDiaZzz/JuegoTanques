{
    "name": "template-vite",
    "description": "A Phaser 3 template using Vite.",
    "version": "1.4.0",
    "type": "module",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/phaserjs/template-vite.git"
    },
    "author": "Phaser Studio <support@phaser.io> (https://phaser.io/)",
    "license": "MIT",
    "licenseUrl": "http://www.opensource.org/licenses/mit-license.php",
    "bugs": {
        "url": "https://github.com/phaserjs/template-vite/issues"
    },
    "homepage": "https://github.com/phaserjs/template-vite#readme",
    "scripts": {
        "dev": "node log.ts dev & vite --config vite/config.dev.mjs",
        "build": "node log.ts build & tsc && vite build --config vite/config.prod.mjs",
        "emit": "node log.ts dev & vite --host --config vite/config.dev.mjs",
        "dev-nolog": "vite --config vite/config.dev.mjs",
        "build-nolog": "tsc && vite build --config vite/config.prod.mjs"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "eslint": "^10.0.2",
        "terser": "^5.39.0",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.56.1",
        "vite": "^6.3.1",
        "vite-plugin-compression": "^0.5.1"
    },
    "dependencies": {
        "phaser": "^3.90.0",
        "phaser-raycaster": "^0.10.11"
    }
}
